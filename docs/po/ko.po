msgid "Resolve an executable inside the active env (v0.11.0)"
msgstr "활성 환경 내 실행 파일 경로 확인 (v0.11.0)"

#: src/llms.md:38
msgid "`scuv run <env> -- <cmd>`"
msgstr "`scuv run <env> -- <cmd>`"

